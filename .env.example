DATABASE_URL=postgresql://user:password@localhost/ai_news

OPENAI_API_KEY=
OPENAI_BASE_URL=
CONTENT_ANALYZER_MODEL=

# FastAPI: set in production to protect POST /api/v1/sources/* and /api/v1/jobs/aggregate
API_KEY=

API_HOST=0.0.0.0
API_PORT=8000

# Web UI lives in a separate folder next to this repo: ../ai-news-web (npm run dev).
# CORS must list the Vite origin if the UI calls the API directly (not via Vite proxy).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_SECRET_KEY=change-me-in-production
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080

SMTP_USERNAME=
SMTP_PASSWORD=

SCHEDULER_ENABLED=true
SCHEDULER_TIMEZONE=UTC
CUSTOM_FETCH_HOUR=8

# On API startup, upsert default RSS/YouTube rows from ai_news_aggregater/data/default_sources.py
SYNC_DEFAULT_SOURCES_ON_STARTUP=false

AGGREGATION_LOOKBACK_HOURS=24
AGGREGATION_RSS_PER_FEED_LIMIT=20
